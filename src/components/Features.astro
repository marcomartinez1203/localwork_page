---
// Features — Clean Premium Bento Grid
const features = [
  {
    icon: '🔍',
    title: 'Búsqueda inteligente',
    description: 'Encuentra oportunidades exactas con filtros avanzados de zona, modalidad y salario. Resultados al instante.',
  },
  {
    icon: '📄',
    title: 'Postulación con CV',
    description: 'Envía tu perfil completo en un clic.',
  },
  {
    icon: '🔔',
    title: 'Alertas en tiempo real',
    description: 'Recibe notificaciones inmediatas.',
  },
  {
    icon: '⭐',
    title: 'Reputación y Feedback',
    description: 'Sistema de calificaciones post-servicio. Empleador y trabajador se evalúan mutuamente con desglose de puntualidad y calidad.',
  },
  {
    icon: '📊',
    title: 'Gestión centralizada',
    description: 'Un dashboard intuitivo para empleadores con embudos de selección visuales.',
  },
  {
    icon: '🌙',
    title: 'Experiencia Nativa',
    description: 'Diseño ultra rápido que se adapta perfectamente a dispositivos móviles y computadoras.',
  },
];

const gridClasses = [
  'md:col-span-7',   // wide
  'md:col-span-5',   // square
  'md:col-span-4',   // square
  'md:col-span-4',   // square
  'md:col-span-4',   // square
  'md:col-span-12',  // banner
];
---

<section id="features" class="relative py-24 sm:py-32 bg-slate-50 overflow-hidden">
  <div class="relative mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    
    <div class="reveal mb-12 md:mb-16 text-center max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-[1.1] mb-4">
        Herramientas de <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-teal-500">nivel empresarial</span>.
      </h2>
      <p class="text-lg text-slate-600">
        Construimos funcionalidades robustas en una interfaz limpia para que te enfoques en lo que importa: el talento.
      </p>
    </div>

    <!-- Premium Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-6">
      {features.map((feature, i) => (
        <div class={`reveal reveal-delay-${Math.min(i + 1, 5)} ${gridClasses[i]} group relative p-8 bg-white rounded-3xl shadow-sm border border-slate-200 hover:shadow-hover transition-all duration-500 hover:-translate-y-1 overflow-hidden ${i === 5 ? 'flex flex-col sm:flex-row sm:items-center gap-6' : ''}`}>
          
          <div class={`w-14 h-14 rounded-2xl bg-slate-50 text-slate-700 flex items-center justify-center text-2xl mb-6 shadow-sm border border-slate-100 group-hover:bg-brand-50 group-hover:text-brand-600 group-hover:border-brand-100 transition-colors duration-300 ${i === 5 ? 'mb-0' : ''}`}>
            {feature.icon}
          </div>

          <div class="flex-1">
            <h3 class="text-xl font-bold text-slate-900 mb-2">
              {feature.title}
            </h3>
            <p class="text-slate-600 leading-relaxed">
              {feature.description}
            </p>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>
