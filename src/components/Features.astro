---
// Features section
const features = [
  {
    icon: '🔍',
    title: 'Búsqueda inteligente',
    description: 'Filtra por modalidad, categoría, zona y salario. Búsqueda sin acentos para encontrar lo que necesitas al instante.',
  },
  {
    icon: '📄',
    title: 'Postulación con CV',
    description: 'Envía tu hoja de vida en PDF o Word directamente desde la plataforma con carta de presentación.',
  },
  {
    icon: '🔔',
    title: 'Notificaciones en tiempo real',
    description: 'Recibe alertas instantáneas cuando alguien se postula, cambia el estado o visita tu perfil.',
  },
  {
    icon: '⭐',
    title: 'Sistema de calificaciones',
    description: 'Los empleadores califican trabajadores y viceversa. Construye tu reputación en la plataforma.',
  },
  {
    icon: '📊',
    title: 'Dashboard de empleador',
    description: 'Panel de control con estadísticas, gestión de ofertas y pipeline de candidatos.',
  },
  {
    icon: '🌙',
    title: 'Modo oscuro nativo',
    description: 'Interfaz adaptable a tu preferencia visual con persistencia automática.',
  },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--color-primary-900)_0%,_transparent_60%)] opacity-30"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary-500/10 border border-primary-500/20 rounded-full text-sm text-primary-400 font-medium mb-6">
        Funcionalidades
      </span>
      <h2 class="font-[Sora] text-3xl sm:text-4xl font-bold text-white mb-4">
        Todo lo que necesitas en un solo lugar
      </h2>
      <p class="text-lg text-gray-400">
        Herramientas diseñadas para simplificar la búsqueda de empleo y la gestión de talento en Aguachica.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="group relative p-6 rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:bg-white/[0.06] hover:border-primary-500/30 transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-4">{feature.icon}</div>
          <h3 class="font-[Sora] text-lg font-semibold text-white mb-2 group-hover:text-primary-400 transition-colors">
            {feature.title}
          </h3>
          <p class="text-sm text-gray-400 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
