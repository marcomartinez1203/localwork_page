---
// CTA + Footer — Premium clean finish
---

<section id="cta" class="relative py-24 sm:py-32 bg-white overflow-hidden border-b border-slate-100">
  <div class="relative mx-auto max-w-[1000px] px-4 sm:px-6 lg:px-10 text-center">
    <div class="reveal">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight mb-6">
        Potencia tu futuro en <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-teal-500">Aguachica</span>.
      </h2>
      <p class="text-lg sm:text-xl text-slate-600 mb-10 max-w-2xl mx-auto">
        Únete a cientos de empresas y talentos que ya están conectando de forma directa y gratuita.
      </p>
    </div>

    <div class="reveal reveal-delay-1 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="https://localwork.app/pages/register.html" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-600 text-white font-medium rounded-2xl shadow-lg shadow-brand-500/30 hover:bg-brand-500 transition-all duration-300 hover:-translate-y-1 w-full sm:w-auto">
        Crear cuenta gratis
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
      </a>
      <a href="https://localwork.app/pages/login.html" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-slate-50 text-slate-700 font-medium rounded-2xl border border-slate-200 hover:bg-slate-100 transition-all duration-300 w-full sm:w-auto">
        Iniciar sesión
      </a>
    </div>

    <div class="reveal reveal-delay-2 mt-10 flex items-center justify-center gap-6 text-sm text-slate-500 font-medium">
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> 100% Gratis</span>
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg> Privacidad total</span>
    </div>
  </div>
</section>

<footer class="bg-slate-50 pt-16 pb-8">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-10 mb-16">
      
      <!-- Brand -->
      <div class="lg:col-span-5">
        <a href="#" class="inline-flex items-center gap-3 mb-6">
          <img src="/logo.png" alt="LocalWork" class="h-8 w-8 rounded-lg shadow-sm" />
          <span class="font-bold text-xl text-slate-900 tracking-tight">
            Local<span class="text-brand-600">Work</span>
          </span>
        </a>
        <p class="text-slate-500 max-w-sm leading-relaxed">
          Plataforma de empleo local diseñada para conectar a la comunidad laboral de Aguachica, Cesar.
          Respaldado por talento local.
        </p>
      </div>

      <!-- Links -->
      <div class="lg:col-span-3 lg:col-start-7">
        <h4 class="font-semibold text-slate-900 mb-5">Navegación</h4>
        <ul class="space-y-3">
          {[
            { label: 'El Problema', href: '#problem' },
            { label: 'Funcionalidades', href: '#features' },
            { label: 'Cómo funciona', href: '#how-it-works' },
            { label: 'Para quién es', href: '#roles' },
          ].map((link) => (
            <li>
              <a href={link.href} class="text-slate-500 hover:text-brand-600 transition-colors duration-300 font-medium">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal / Contact -->
      <div class="lg:col-span-3">
        <h4 class="font-semibold text-slate-900 mb-5">Legal</h4>
        <ul class="space-y-3">
          <li><a href="#" class="text-slate-500 hover:text-brand-600 transition-colors duration-300 font-medium">Términos de servicio</a></li>
          <li><a href="#" class="text-slate-500 hover:text-brand-600 transition-colors duration-300 font-medium">Política de privacidad</a></li>
          <li><a href="#" class="text-slate-500 hover:text-brand-600 transition-colors duration-300 font-medium">Contacto</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="pt-8 border-t border-slate-200 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500 font-medium">
        &copy; {new Date().getFullYear()} LocalWork. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-2 text-sm text-slate-500 font-medium">
        <span>Hecho con</span>
        <svg class="w-4 h-4 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg>
        <span>en Aguachica, Cesar</span>
      </div>
    </div>
  </div>
</footer>
