---
// Hero — Premium Light Theme
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-28 pb-12">
  <!-- Soft background gradients -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-brand-200/40 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-[10%] left-[-10%] w-[500px] h-[500px] bg-blue-200/30 rounded-full blur-[100px]"></div>
    <!-- Clean dot grid -->
    <div class="absolute inset-0 opacity-[0.4]" style="background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 32px 32px;"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-[1400px] w-full px-4 sm:px-6 lg:px-10">
    
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-8">
      
      <!-- Left side: Typography & CTA -->
      <div class="w-full lg:w-1/2 flex flex-col justify-center lg:pr-8">
        <div class="reveal mb-6">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-white border border-slate-200 rounded-full shadow-sm">
            <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
            <span class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Aguachica, Cesar</span>
          </div>
        </div>

        <div class="reveal reveal-delay-1 mb-8">
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-slate-900 leading-[1.05]">
            El empleo local,<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-teal-500">simplificado.</span>
          </h1>
          <p class="mt-6 text-lg sm:text-xl text-slate-600 leading-relaxed max-w-xl">
            Conectamos a <span class="font-semibold text-slate-900">buscadores de empleo</span>, 
            <span class="font-semibold text-slate-900">trabajadores independientes</span> y 
            <span class="font-semibold text-slate-900">empleadores</span> en una sola plataforma diseñada para nuestra comunidad.
          </p>
        </div>

        <div class="reveal reveal-delay-2 flex flex-col sm:flex-row gap-4">
          <a href="https://local-work-six.vercel.app/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-slate-900 text-white font-medium rounded-2xl shadow-lg hover:bg-slate-800 transition-all duration-300 hover:-translate-y-1 group">
            Crear cuenta gratis
            <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>
          <a href="#features" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-slate-700 font-medium rounded-2xl shadow-sm border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all duration-300">
            Ver funciones
          </a>
        </div>
        
        <div class="reveal reveal-delay-3 mt-8 flex items-center gap-6">
          <div class="flex items-center gap-2 text-sm font-medium text-slate-600">
            <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            100% Gratuito
          </div>
          <div class="flex items-center gap-2 text-sm font-medium text-slate-600">
            <svg class="w-5 h-5 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            Sin comisiones
          </div>
        </div>
      </div>

      <!-- Right side: Bento Grid visual -->
      <div class="w-full lg:w-1/2">
        <div class="grid grid-cols-2 gap-4">
          
          <!-- Top wide card -->
          <div class="reveal reveal-delay-2 col-span-2 p-6 bg-white rounded-3xl shadow-soft border border-slate-100 flex items-center gap-5 group hover:shadow-hover transition-all duration-500">
            <div class="w-14 h-14 rounded-2xl bg-brand-50 text-brand-600 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform duration-300">
              👋
            </div>
            <div>
              <p class="text-sm font-medium text-brand-600 mb-1">Nueva postulación</p>
              <p class="text-slate-900 font-semibold">Carlos M. ha aplicado a tu oferta</p>
              <p class="text-sm text-slate-500 mt-1">Hace 2 minutos</p>
            </div>
          </div>

          <!-- Bottom left stat card -->
          <div class="reveal reveal-delay-3 p-6 bg-slate-900 rounded-3xl shadow-soft flex flex-col justify-between overflow-hidden relative group hover:shadow-hover transition-all duration-500">
            <div class="absolute -right-4 -top-4 w-24 h-24 bg-brand-500/20 rounded-full blur-xl group-hover:bg-brand-500/30 transition-colors"></div>
            <p class="text-brand-400 font-medium mb-8">Talento local</p>
            <div>
              <p class="text-4xl font-bold text-white mb-2">+150</p>
              <p class="text-sm text-slate-400">Trabajadores activos</p>
            </div>
          </div>

          <!-- Bottom right feature card -->
          <div class="reveal reveal-delay-4 p-6 bg-white rounded-3xl shadow-soft border border-slate-100 flex flex-col justify-between group hover:shadow-hover transition-all duration-500">
            <div class="w-12 h-12 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center text-xl mb-8 group-hover:scale-110 transition-transform duration-300">
              ⚡
            </div>
            <div>
              <p class="text-lg font-semibold text-slate-900 mb-1">Rápido</p>
              <p class="text-sm text-slate-500">Conexiones directas sin intermediarios.</p>
            </div>
          </div>

        </div>
      </div>

    </div>
  </div>

  <!-- Marquee ticker -->
  <div class="mt-auto pt-16">
    <div class="flex animate-marquee whitespace-nowrap overflow-hidden py-4 border-y border-slate-200/60 bg-white/50 backdrop-blur-sm">
      {Array(4).fill(null).map(() => (
        <span class="inline-flex items-center gap-8 mx-6 text-sm font-semibold text-slate-400 uppercase tracking-wider">
          <span>Empleo local</span><span class="text-brand-300">●</span>
          <span>Talento real</span><span class="text-brand-300">●</span>
          <span>Aguachica</span><span class="text-brand-300">●</span>
          <span>Postulación en 1 clic</span><span class="text-brand-300">●</span>
          <span>Notificaciones 24/7</span><span class="text-brand-300">●</span>
          <span>100% gratuito</span><span class="text-brand-300">●</span>
        </span>
      ))}
    </div>
  </div>
</section>
