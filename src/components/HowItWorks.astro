---
// How it works section
const steps = [
  {
    number: '01',
    title: 'Crea tu cuenta',
    description: 'Regístrate como buscador de empleo o como empleador. Solo necesitas un correo y una contraseña.',
    accent: 'from-primary-500 to-primary-400',
  },
  {
    number: '02',
    title: 'Completa tu perfil',
    description: 'Agrega tu experiencia, habilidades, educación y sube tu hoja de vida para que los empleadores te encuentren.',
    accent: 'from-primary-400 to-accent-400',
  },
  {
    number: '03',
    title: 'Conecta con oportunidades',
    description: 'Explora ofertas, postúlate con un clic, o publica vacantes y recibe candidatos en tu dashboard.',
    accent: 'from-accent-400 to-yellow-400',
  },
];
---

<section id="how-it-works" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary-500/10 border border-primary-500/20 rounded-full text-sm text-primary-400 font-medium mb-6">
        Cómo funciona
      </span>
      <h2 class="font-[Sora] text-3xl sm:text-4xl font-bold text-white mb-4">
        Tres pasos para empezar
      </h2>
      <p class="text-lg text-gray-400">
        Sin complicaciones. Sin costos. Empieza a conectar hoy.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step, i) => (
        <div class="relative text-center group">
          {/* Connector line */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-12 left-[60%] w-[80%] h-px bg-gradient-to-r from-white/10 to-transparent"></div>
          )}

          <div class={`inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br ${step.accent} text-white font-[Sora] text-2xl font-bold mb-6 shadow-lg shadow-primary-500/20 group-hover:scale-110 transition-transform duration-300`}>
            {step.number}
          </div>
          <h3 class="font-[Sora] text-xl font-semibold text-white mb-3">{step.title}</h3>
          <p class="text-gray-400 leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
