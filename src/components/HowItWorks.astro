---
// How it works — Clean horizontal steps
const steps = [
  {
    number: '01',
    title: 'Crea tu cuenta',
    description: 'Registro simple en segundos. Como buscador de empleo o como empresa empleadora.',
    icon: 'user-plus',
  },
  {
    number: '02',
    title: 'Completa el perfil',
    description: 'Sube tu hoja de vida o llena el formulario. Muestra tus habilidades al mundo.',
    icon: 'document-text',
  },
  {
    number: '03',
    title: 'Haz match y califica',
    description: 'Conecta directamente y, al finalizar el trabajo, califica tu experiencia para construir confianza mutua.',
    icon: 'sparkles',
  },
];
---

<section id="how-it-works" class="relative py-24 sm:py-32 bg-white overflow-hidden border-y border-slate-100">
  <div class="relative mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    
    <div class="reveal mb-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-4">
        Diseñado para ser <span class="text-brand-600">intuitivo</span>.
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        Empieza a conectar con el ecosistema laboral de Aguachica en tres pasos simples.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12 relative">
      <!-- Desktop connector line -->
      <div class="hidden md:block absolute top-12 left-[15%] right-[15%] h-[2px] bg-slate-100"></div>

      {steps.map((step, i) => (
        <div class={`reveal reveal-delay-${i + 1} relative group text-center`}>
          <!-- Icon Circle -->
          <div class="relative w-24 h-24 mx-auto mb-8 bg-white rounded-full flex items-center justify-center border-[6px] border-white shadow-soft z-10 group-hover:scale-110 transition-transform duration-500">
            <div class="absolute inset-0 bg-brand-50 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500"></div>
            <span class="relative z-10 text-2xl font-bold text-slate-400 group-hover:text-brand-600 transition-colors duration-300">
              {step.number}
            </span>
          </div>

          <h3 class="text-xl font-bold text-slate-900 mb-3">{step.title}</h3>
          <p class="text-slate-600 leading-relaxed max-w-sm mx-auto">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
