---
// Navbar — Premium Light Theme
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="#" class="flex items-center gap-3 group">
        <div class="relative">
          <img
            src="/logo.png"
            alt="LocalWork"
            class="h-10 w-10 rounded-xl shadow-sm transition-transform duration-300 group-hover:scale-105"
          />
        </div>
        <span class="font-bold text-xl text-slate-900 tracking-tight">
          Local<span class="text-brand-600">Work</span>
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-2 bg-white/70 backdrop-blur-md px-4 py-2 rounded-full shadow-[0_2px_8px_rgba(0,0,0,0.04)] border border-slate-200/50">
        {['Problema', 'Funciones', 'Para quién', 'Tecnología', 'Equipo'].map((label, i) => {
          const ids = ['#problem', '#features', '#roles', '#tech', '#team'];
          return (
            <a
              href={ids[i]}
              class="relative px-4 py-1.5 text-sm font-medium text-slate-600 hover:text-brand-600 transition-colors duration-300 rounded-full hover:bg-brand-50"
            >
              {label}
            </a>
          );
        })}
      </div>

      <!-- CTA + Mobile Toggle -->
      <div class="flex items-center gap-4">
        <a
          href="https://localwork-aguachica.vercel.app/"
          class="hidden sm:inline-flex items-center gap-2 px-6 py-2.5 bg-brand-600 text-white text-sm font-medium rounded-full shadow-lg shadow-brand-500/25 hover:bg-brand-500 transition-all duration-300 hover:-translate-y-0.5 active:scale-95"
        >
          Empezar
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>

        <!-- Mobile hamburger -->
        <button
          id="mobile-toggle"
          class="md:hidden relative w-10 h-10 flex flex-col items-center justify-center gap-1.5 group bg-white rounded-full shadow-sm border border-slate-200"
          aria-label="Menú"
        >
          <span class="block w-5 h-0.5 bg-slate-700 transition-all duration-300 origin-center group-[.open]:rotate-45 group-[.open]:translate-y-2"></span>
          <span class="block w-5 h-0.5 bg-slate-700 transition-all duration-300 group-[.open]:opacity-0"></span>
          <span class="block w-5 h-0.5 bg-slate-700 transition-all duration-300 origin-center group-[.open]:rotate-[-45deg] group-[.open]:-translate-y-2"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden max-h-0 overflow-hidden transition-all duration-500 bg-white/95 backdrop-blur-xl border-b border-slate-200 shadow-lg">
    <div class="px-6 py-6 space-y-1">
      {['Problema', 'Funciones', 'Para quién', 'Tecnología', 'Equipo'].map((label, i) => {
        const ids = ['#problem', '#features', '#roles', '#tech', '#team'];
        return (
          <a
            href={ids[i]}
            class="mobile-link block py-3 text-base font-medium text-slate-600 hover:text-brand-600 hover:bg-brand-50 px-4 rounded-xl transition-all duration-300"
          >
            {label}
          </a>
        );
      })}
      <div class="px-4 pt-4 mt-2 border-t border-slate-100">
        <a
          href="https://localwork-aguachica.vercel.app/"
          class="block w-full py-3 text-center bg-brand-600 text-white font-medium rounded-xl shadow-md hover:bg-brand-500 transition-all duration-300"
        >
          Empezar ahora →
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  let lastY = 0;
  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    if (y > 20) {
      nav?.classList.add('bg-white/80', 'backdrop-blur-xl', 'border-b', 'border-slate-200/60', 'shadow-sm');
    } else {
      nav?.classList.remove('bg-white/80', 'backdrop-blur-xl', 'border-b', 'border-slate-200/60', 'shadow-sm');
    }
    lastY = y;
  });

  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    toggle.classList.toggle('open');
    if (menu) {
      menu.style.maxHeight = toggle.classList.contains('open') ? menu.scrollHeight + 'px' : '0';
    }
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.classList.remove('open');
      if (menu) menu.style.maxHeight = '0';
    });
  });
</script>
