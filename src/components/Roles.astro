---
// Roles — Professional audience segmented cards
const roles = [
  {
    badge: 'Para Talento',
    role: 'Buscador de empleo',
    features: [
      'Filtros por zona, modalidad y categoría',
      'Postulación rápida con CV',
      'Seguimiento en tiempo real',
    ],
    bg: 'bg-blue-50',
    text: 'text-blue-700',
    border: 'border-blue-200',
    shadow: 'shadow-blue-900/5',
  },
  {
    badge: 'Para Independientes',
    role: 'Trabajadores locales',
    features: [
      'Perfil en directorio público',
      'Muestra de habilidades y tarifas',
      'Reputación y calificaciones',
    ],
    bg: 'bg-brand-50',
    text: 'text-brand-700',
    border: 'border-brand-200',
    shadow: 'shadow-brand-900/5',
  },
  {
    badge: 'Para Empresas',
    role: 'Empleador / Negocio',
    features: [
      'Dashboard estadístico completo',
      'Gestión de pipeline de candidatos',
      'Notificaciones instantáneas',
    ],
    bg: 'bg-slate-900',
    text: 'text-white',
    border: 'border-slate-800',
    shadow: 'shadow-slate-900/20',
    isDark: true,
  },
];
---

<section id="roles" class="relative py-24 sm:py-32 bg-slate-50 overflow-hidden">
  <div class="relative mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    
    <div class="reveal mb-16 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-[1.1] mb-4">
        Una plataforma.<br />
        <span class="text-slate-400">Hecha para todos.</span>
      </h2>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-stretch">
      {roles.map((role, i) => (
        <div class={`reveal reveal-delay-${i + 1} relative p-8 sm:p-10 rounded-[2rem] ${role.bg} ${role.isDark ? '' : 'border'} ${role.border} shadow-lg ${role.shadow} hover:-translate-y-2 transition-transform duration-500 flex flex-col`}>
          
          <div class="mb-8">
            <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-4 ${role.isDark ? 'bg-slate-800 text-slate-300' : 'bg-white shadow-sm ' + role.text}`}>
              {role.badge}
            </span>
            <h3 class={`text-2xl font-extrabold ${role.isDark ? 'text-white' : 'text-slate-900'}`}>{role.role}</h3>
          </div>

          <ul class="space-y-4 mb-8 flex-1">
            {role.features.map((f) => (
              <li class={`flex items-start gap-3 text-sm ${role.isDark ? 'text-slate-400' : 'text-slate-600'}`}>
                <svg class={`w-5 h-5 flex-shrink-0 mt-0.5 ${role.isDark ? 'text-brand-400' : role.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>

          <a href="https://local-work-drab.vercel.app/" class={`mt-auto inline-flex items-center justify-between w-full py-3 px-5 rounded-xl font-medium transition-colors ${role.isDark ? 'bg-white text-slate-900 hover:bg-slate-100' : 'bg-white border border-slate-200 text-slate-700 hover:bg-slate-50'}`}>
            Explorar
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
          </a>

        </div>
      ))}
    </div>
  </div>
</section>
