---
// Roles section
const roles = [
  {
    emoji: '🔍',
    role: 'Buscador de empleo',
    features: [
      'Explorar y filtrar ofertas por zona, modalidad y categoría',
      'Postularse con carta de presentación y CV adjunto',
      'Seguimiento en tiempo real del estado de cada postulación',
      'Guardar empleos favoritos para revisar después',
      'Perfil completo con educación, experiencia y habilidades',
      'Compartir ofertas con amigos y contactos',
    ],
    gradient: 'from-blue-500/20 to-primary-500/20',
    border: 'hover:border-blue-500/30',
  },
  {
    emoji: '👷',
    role: 'Trabajador independiente',
    features: [
      'Perfil público visible en el directorio de trabajadores',
      'Muestra tus habilidades, disponibilidad y tarifa',
      'Recibe notificaciones cuando empleadores ven tu perfil',
      'Acumula calificaciones y construye tu reputación',
      'Aparece en búsquedas por habilidad y zona',
      'Conecta directamente con empresas locales',
    ],
    gradient: 'from-primary-500/20 to-accent-400/20',
    border: 'hover:border-primary-500/30',
  },
  {
    emoji: '💼',
    role: 'Empleador',
    features: [
      'Dashboard con estadísticas de tus ofertas y postulaciones',
      'Crear, editar y gestionar ofertas con vencimiento automático',
      'Revisar candidatos y moverlos en el pipeline de selección',
      'Perfil de empresa con logo, NIT, dirección y sitio web',
      'Calificar trabajadores después de contratarlos',
      'Notificaciones en tiempo real de nuevas postulaciones',
    ],
    gradient: 'from-accent-400/20 to-yellow-500/20',
    border: 'hover:border-accent-400/30',
  },
];
---

<section id="roles" class="relative py-24 sm:py-32">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--color-primary-900)_0%,_transparent_50%)] opacity-20"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary-500/10 border border-primary-500/20 rounded-full text-sm text-primary-400 font-medium mb-6">
        Para quién es
      </span>
      <h2 class="font-[Sora] text-3xl sm:text-4xl font-bold text-white mb-4">
        Una plataforma, tres perfiles
      </h2>
      <p class="text-lg text-gray-400">
        Cada tipo de usuario tiene herramientas diseñadas para sus necesidades.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid lg:grid-cols-3 gap-6">
      {roles.map((role) => (
        <div class={`relative p-8 rounded-2xl bg-gradient-to-br ${role.gradient} border border-white/[0.06] ${role.border} transition-all duration-300 hover:-translate-y-1`}>
          <div class="text-4xl mb-4">{role.emoji}</div>
          <h3 class="font-[Sora] text-xl font-bold text-white mb-6">{role.role}</h3>
          <ul class="space-y-3">
            {role.features.map((f) => (
              <li class="flex items-start gap-3 text-sm text-gray-300">
                <span class="text-accent-400 mt-0.5 flex-shrink-0">✓</span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
