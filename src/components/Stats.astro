---
// Stats section
const stats = [
  { value: '10+', label: 'Categorías de empleo', icon: '📂' },
  { value: '3', label: 'Tipos de modalidad', icon: '🏢' },
  { value: '6', label: 'Estados de postulación', icon: '📋' },
  { value: '24/7', label: 'Notificaciones en vivo', icon: '⚡' },
];
---

<section id="stats" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-3xl bg-gradient-to-br from-primary-500/10 via-primary-900/20 to-accent-400/5 border border-white/[0.06] p-12 sm:p-16 overflow-hidden">
      <!-- Background decoration -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary-500/10 rounded-full blur-[80px]"></div>
      <div class="absolute bottom-0 left-0 w-48 h-48 bg-accent-400/5 rounded-full blur-[60px]"></div>

      <div class="relative">
        <div class="text-center mb-12">
          <h2 class="font-[Sora] text-3xl sm:text-4xl font-bold text-white mb-4">
            Diseñado para el impacto local
          </h2>
          <p class="text-gray-400 max-w-2xl mx-auto">
            LocalWork nace de la necesidad de Aguachica. Una plataforma que entiende el mercado laboral de nuestro municipio.
          </p>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center group">
              <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">{stat.icon}</div>
              <div class="font-[Sora] text-3xl sm:text-4xl font-extrabold text-white mb-1">{stat.value}</div>
              <div class="text-sm text-gray-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
