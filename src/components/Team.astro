---
// Team section
// ⚠️ ACTUALIZA estos datos con los integrantes reales de tu equipo
const team = [
  {
    name: 'Marco Martínez',
    role: 'Desarrollador',
    bio: 'Encargado de la arquitectura del backend, diseño de base de datos y desarrollo del frontend.',
    avatar: '👨‍💻',
    github: 'marcomartinez1203',
  },
  {
    name: 'Cristian Jimenez',
    role: 'Diseño UI/UX & Frontend',
    bio: 'Responsable del sistema de diseño y documentación del proyecto.',
    avatar: '🎨',
    github: '',
  },
  {
    name: 'Kevin Blanco',
    role: 'Director de proyecto',
    bio: 'Lider del proyecto y comunicador del equipo.',
    avatar: '⚙️',
    github: '',
  },
  
];
---

<section id="team" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="inline-block px-4 py-1.5 bg-primary-500/10 border border-primary-500/20 rounded-full text-sm text-primary-400 font-medium mb-6">
        Nuestro equipo
      </span>
      <h2 class="font-[Sora] text-3xl sm:text-4xl font-bold text-white mb-4">
        Quiénes somos
      </h2>
      <p class="text-lg text-gray-400">
        Estudiantes comprometidos con el desarrollo tecnológico de Aguachica.
      </p>
    </div>

    <!-- Team grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
      {team.map((member) => (
        <div class="group relative p-6 rounded-2xl bg-white/[0.03] border border-white/[0.06] hover:bg-white/[0.06] hover:border-primary-500/20 transition-all duration-300 hover:-translate-y-1 text-center">
          <!-- Avatar -->
          <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-primary-500/20 to-accent-400/10 border border-white/10 flex items-center justify-center text-4xl group-hover:scale-110 transition-transform duration-300">
            {member.avatar}
          </div>

          <h3 class="font-[Sora] text-base font-semibold text-white mb-1">{member.name}</h3>
          <p class="text-xs text-primary-400 font-medium mb-3">{member.role}</p>
          <p class="text-xs text-gray-500 leading-relaxed mb-4">{member.bio}</p>

          {member.github && (
            <a
              href={`https://github.com/${member.github}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs text-gray-500 hover:text-white transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/>
              </svg>
              @{member.github}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
