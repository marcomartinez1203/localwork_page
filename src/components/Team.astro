---
// Team — Corporate / Startup profiles
const team = [
  {
    name: 'Marco Martínez',
    role: 'Full Stack Engineer',
    bio: 'Arquitecto del sistema.',
    avatar: '👨‍💻',
    github: 'marcomartinez1203',
  },
  {
    name: 'Cristian Jimenez',
    role: 'Product Designer y Documentador',
    bio: 'Responsable de la experiencia e interfaz de usuario y documentacion del proyecto.',
    avatar: '🎨',
    github: '',
  },
  {
    name: 'Kevin Blanco',
    role: 'Project Manager',
    bio: 'Dirección, estrategia y comunicación.',
    avatar: '⚙️',
    github: '',
  },
];
---

<section id="team" class="relative py-24 sm:py-32 bg-slate-50 overflow-hidden">
  <div class="relative mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    
    <div class="reveal mb-16 text-center">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-4">
        El talento detrás.
      </h2>
      <p class="text-lg text-slate-600">
        Construyendo soluciones locales con estándares globales.
      </p>
    </div>

    <!-- Profiles Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {team.map((member, i) => (
        <div class={`reveal reveal-delay-${i + 1} bg-white rounded-3xl p-8 border border-slate-200 shadow-sm hover:shadow-hover transition-all duration-500 text-center group`}>
          
          <div class="w-20 h-20 mx-auto rounded-full bg-slate-50 flex items-center justify-center text-4xl mb-5 shadow-inner border border-slate-100 group-hover:scale-110 group-hover:bg-brand-50 transition-all duration-300">
            {member.avatar}
          </div>

          <h3 class="text-lg font-bold text-slate-900 mb-1">{member.name}</h3>
          <p class="text-sm font-semibold text-brand-600 mb-3">{member.role}</p>
          <p class="text-sm text-slate-500 mb-6">{member.bio}</p>

          {member.github ? (
            <a href={`https://github.com/${member.github}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-slate-50 text-slate-400 hover:bg-slate-900 hover:text-white transition-colors duration-300 mx-auto">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.085 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.604-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12"/></svg>
            </a>
          ) : (
             <div class="w-10 h-10 mx-auto"></div>
          )}

        </div>
      ))}
    </div>
  </div>
</section>
