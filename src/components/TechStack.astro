---
// Tech Stack — Premium modern grid
const stack = [
  {
    category: 'Backend',
    icon: '⚡',
    items: [
      { name: 'Node.js', desc: 'Runtime de servidor' },
      { name: 'Express', desc: 'Framework web' },
      { name: 'TypeScript', desc: 'Tipado estático' },
    ],
  },
  {
    category: 'Base de datos',
    icon: '🐘',
    items: [
      { name: 'Supabase', desc: 'Backend as a Service' },
      { name: 'PostgreSQL', desc: 'Base de datos relacional' },
      { name: 'Realtime', desc: 'Sincronización en vivo' },
    ],
  },
  {
    category: 'Frontend',
    icon: '🎨',
    items: [
      { name: 'Vue 3 + Vite', desc: 'SPA de alto rendimiento' },
      { name: 'Astro', desc: 'Landing ultra rápida' },
      { name: 'TypeScript', desc: 'Interfaces seguras' },
    ],
  },
  {
    category: 'Seguridad',
    icon: '🛡️',
    items: [
      { name: 'RLS', desc: 'Row Level Security' },
      { name: 'Helmet', desc: 'Headers HTTP' },
      { name: 'CORS', desc: 'Control de acceso' },
    ],
  },
];
---

<section id="tech" class="relative py-24 sm:py-32 bg-white overflow-hidden border-t border-slate-100">
  <div class="relative mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-10">
    
    <div class="reveal mb-16 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-slate-900 leading-[1.1] mb-4">
        Arquitectura de <span class="text-brand-600">vanguardia</span>.
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        No escatimamos en tecnología. Usamos el mismo stack moderno que las empresas líderes mundiales.
      </p>
    </div>

    <!-- Tech Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {stack.map((group, i) => (
        <div class={`reveal reveal-delay-${i + 1} p-8 bg-slate-50 rounded-3xl border border-slate-200 hover:shadow-lg hover:shadow-slate-200/50 transition-all duration-500 group hover:-translate-y-1`}>
          
          <div class="w-12 h-12 rounded-xl bg-white shadow-sm border border-slate-100 flex items-center justify-center text-2xl mb-6 group-hover:scale-110 transition-transform duration-300">
            {group.icon}
          </div>

          <h3 class="text-lg font-bold text-slate-900 mb-6">{group.category}</h3>

          <ul class="space-y-4">
            {group.items.map((item) => (
              <li>
                <p class="text-sm font-semibold text-slate-800 mb-0.5">{item.name}</p>
                <p class="text-xs text-slate-500">{item.desc}</p>
              </li>
            ))}
          </ul>

        </div>
      ))}
    </div>
  </div>
</section>
